@charset "utf-8";

*, ::before, ::after { box-sizing: border-box; margin: 0px; padding: 0px; }

:root { --red: #c8102e; --red-dark: #8b0a1f; --red-glow: rgba(200, 16, 46, 0.35); --gold: #f5c518; --bg: #0a0a0b; --surface: #111114; --surface-2: #18181c; --border: rgba(200,16,46,0.2); --text: #f0ede8; --text-muted: #9a9490; --font-display: 'Oswald', sans-serif; --font-body: 'Inter', sans-serif; }

html { scroll-behavior: smooth; }

body { min-height: 100dvh; background: var(--bg); color: var(--text); font-family: var(--font-body); display: flex; flex-direction: column; align-items: center; justify-content: center; overflow-x: hidden; position: relative; }

body::before { content: ""; position: fixed; inset: 0px; background: radial-gradient(80% 50% at 50% 0%, rgba(200, 16, 46, 0.18) 0%, transparent 60%), radial-gradient(60% 40% at 50% 100%, rgba(200, 16, 46, 0.08) 0%, transparent 50%); pointer-events: none; z-index: 0; }

.particles { position: fixed; inset: 0px; pointer-events: none; z-index: 0; overflow: hidden; }

.particle { position: absolute; width: 2px; height: 2px; border-radius: 50%; background: var(--red); opacity: 0; animation: auto linear 0s infinite normal none running float; }

@keyframes float { 
  0% { transform: translateY(100vh) scale(0); opacity: 0; }
  10% { opacity: 0.4; }
  90% { opacity: 0.2; }
  100% { transform: translateY(-10vh) scale(1.5); opacity: 0; }
}

.wrapper { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 2rem; padding: 2rem 1.5rem; width: 100%; max-width: 900px; text-align: center; }

.badge { display: inline-flex; flex-direction: column; align-items: center; gap: 0.5rem; }

.eagle-svg { width: 80px; height: 80px; filter: drop-shadow(0 0 16px var(--red-glow)); animation: 3s ease-in-out 0s infinite normal none running pulse-glow; }

@keyframes pulse-glow { 
  0%, 100% { filter: drop-shadow(0 0 12px var(--red-glow)); }
  50% { filter: drop-shadow(rgba(200, 16, 46, 0.6) 0px 0px 28px); }
}

.club-name { font-family: var(--font-display); font-size: clamp(0.75rem, 2vw, 0.9rem); letter-spacing: 0.35em; text-transform: uppercase; color: var(--text-muted); font-weight: 400; }

.headline { font-family: var(--font-display); font-weight: 700; font-size: clamp(2.4rem, 8vw, 5.5rem); line-height: 1; text-transform: uppercase; letter-spacing: 0.04em; color: var(--text); }

.headline span { color: var(--red); display: block; }

.counter { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; width: 100%; max-width: 700px; }

.counter-block { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem 0.75rem 1.25rem; position: relative; overflow: hidden; transition: border-color 0.3s, box-shadow 0.3s; }

.counter-block::before { content: ""; position: absolute; top: 0px; left: 0px; right: 0px; height: 2px; background: linear-gradient(90deg, transparent, var(--red), transparent); opacity: 0.7; }

.counter-block:hover { border-color: rgba(200, 16, 46, 0.5); box-shadow: rgba(200, 16, 46, 0.12) 0px 0px 24px; }

.counter-num { font-family: var(--font-display); font-weight: 700; font-size: clamp(2rem, 6vw, 4rem); line-height: 1; color: var(--text); letter-spacing: -0.02em; display: block; transition: transform 0.15s, color 0.15s; }

.counter-num.tick { transform: scale(1.12); color: var(--red); }

.counter-label { display: block; font-family: var(--font-body); font-size: clamp(0.6rem, 1.5vw, 0.75rem); font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); margin-top: 0.5rem; }

.last-match { background: var(--surface-2); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.5rem; display: flex; flex-direction: column; gap: 0.3rem; }

.last-match-label { font-size: 0.7rem; font-weight: 500; letter-spacing: 0.2em; text-transform: uppercase; color: var(--text-muted); }

.last-match-info { font-family: var(--font-display); font-size: clamp(0.9rem, 2.5vw, 1.2rem); color: var(--text); font-weight: 600; letter-spacing: 0.04em; }

.last-match-info .score { color: var(--red); }

.live-indicator { display: flex; align-items: center; gap: 0.5rem; font-size: 0.72rem; color: var(--text-muted); font-weight: 400; letter-spacing: 0.1em; }

.dot { width: 8px; height: 8px; border-radius: 50%; background: var(--red); animation: 1.4s ease-in-out 0s infinite normal none running blink; flex-shrink: 0; }

@keyframes blink { 
  0%, 100% { opacity: 1; box-shadow: 0 0 6px var(--red); }
  50% { opacity: 0.3; box-shadow: none; }
}

footer { position: relative; z-index: 1; color: var(--text-muted); font-size: 0.72rem; letter-spacing: 0.05em; padding: 1.5rem; text-align: center; line-height: 1.6; }

footer a { color: var(--red); text-decoration: none; }

@media (max-width: 480px) {
  .counter { grid-template-columns: repeat(2, 1fr); gap: 0.75rem; }
  .counter-block { padding: 1.25rem 0.5rem 1rem; }
}

@media (prefers-reduced-motion: reduce) {
  *, ::before, ::after { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; }
}
